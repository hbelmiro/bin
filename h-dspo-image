#!/usr/bin/env zsh

SCRIPT_DIR="$(dirname "$0")"
source "$SCRIPT_DIR"/handle_error

USE_DOCKER=false

while [[ "$#" -gt 0 ]]; do
  case $1 in
    --docker)
      USE_DOCKER=true
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
  shift
done

IMAGE=""
if [ "$USE_DOCKER" = true ]; then
  IMAGE=$(h-podman-build-dev -d dspo) || handle_error "Failed to build Docker container image"
else
  IMAGE=$(h-podman-build-dev dspo) || handle_error "Failed to build Quay container image"
fi

# Push progress must not go to stdout — callers use $(h-dspo-image) and need only the image ref.
podman push "$IMAGE" 1>&2 || handle_error "Failed to push container image"
echo "$IMAGE"